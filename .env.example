# ── Database ─────────────────────────────────────────────────────────────────
# The app connects to the host PostgreSQL cluster THROUGH the db-router (HAProxy)
# as user "roman" → database "db_roman". The full DATABASE_URL / DATABASE_URL_SYNC
# are assembled in docker-compose.yml from DB_PASSWORD, so you only set the
# password here.
DB_PASSWORD=change-me

# Anthropic (Claude) — required
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — required (embeddings for RAG + Whisper transcription)
OPENAI_API_KEY=sk-...

# Tavily (web search) — optional; app degrades gracefully if empty
TAVILY_API_KEY=tvly-...

# App password gate — empty disables auth
APP_PASSWORD=

# Cookie signing secret — set to a long random string in production
COOKIE_SECRET=change-me-in-production

# Set true when served over HTTPS (e.g. behind Cloudflare Tunnel)
# COOKIE_SECURE=true

# ── Running OUTSIDE Docker (local dev) only ────────────────────────────────────
# In Docker these are set by docker-compose.yml. If you run uvicorn directly,
# uncomment them — python-dotenv interpolates ${DB_PASSWORD} from above.
# DATABASE_URL_SYNC=postgresql://roman:${DB_PASSWORD}@db-router:5432/db_roman
# DATABASE_URL=postgresql+asyncpg://roman:${DB_PASSWORD}@db-router:5432/db_roman
